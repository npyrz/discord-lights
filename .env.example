# Copy this file to ".env" and fill in your own values.
#   PowerShell:  Copy-Item .env.example .env
#   bash:        cp .env.example .env

# --- Discord ---
# Bot token from https://discord.com/developers/applications -> Bot -> Reset Token
DISCORD_TOKEN=your-discord-bot-token
# Optional: your server (guild) ID so slash commands appear instantly.
# Leave blank for a global sync (can take up to ~1 hour to show up).
DISCORD_GUILD_ID=

# Optional: a Discord role ID. Members with this role can always control the
# lights and can lock/unlock them for everyone else with /lightaccess.
# Leave blank to let anyone use the lights. (Enable Developer Mode in Discord,
# then right-click the role -> Copy Role ID.)
LIGHT_ADMIN_ROLE_ID=

# --- Tuya Cloud (iot.tuya.com) ---
# From your Tuya IoT Platform cloud project.
TUYA_CLIENT_ID=your-tuya-access-id
TUYA_CLIENT_SECRET=your-tuya-access-secret
TUYA_DEVICE_ID=your-device-id
# Data center region: us / eu / cn / in  (us = Western America)
TUYA_REGION=us
